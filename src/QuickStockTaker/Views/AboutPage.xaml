<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="QuickStockTaker.Views.AboutPage"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit" 
             xmlns:fa="clr-namespace:FontAwesome"
             xmlns:viewModels="clr-namespace:QuickStockTaker.Core.ViewModels;assembly=QuickStockTaker.Core"
             x:Name="About"
             x:DataType="viewModels:AboutViewModel"
             Title="AboutPage">
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
                EventName="Appearing"
                Command="{Binding Source={x:Reference About}, Path=BindingContext.AppearingCommand}" x:DataType="ContentPage"
                 />
        <!--<toolkit:EventToCommandBehavior
                EventName="Disappearing"
                Command="{Binding DisappearingCommand}" />-->
    </ContentPage.Behaviors>
    <ContentPage.Content>
        <ScrollView Padding="15">
            <StackLayout Orientation="Vertical" Padding="16,10,16,40" Spacing="10">
                <Image Source="ic_stocktake" HeightRequest="100" Margin="0,50,0,20"/>

                <Label HorizontalTextAlignment="Justify">Thank you  for trying Quick StockTaker!</Label>
                <Label HorizontalTextAlignment="Justify">This app is free to use for personal and commercial. If you have any questions, comments, suggestions, or features you'd like to see, I'd appreciate your feedback.</Label>
                <Label HorizontalTextAlignment="Justify">If you'd like to show your support for this project and help me continue development, please consider a donation.</Label>
                <Label>
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Project home: " />
                            <Span Text="https://github.com/jedipi/Quick-Stocktaker"
                  TextColor="Blue"
                  TextDecorations="Underline">
                                <Span.GestureRecognizers>
                                    <TapGestureRecognizer x:DataType="viewModels:AboutViewModel"
                                          Command="{Binding ProjectHomeCommand}"
                                          CommandParameter="https://github.com/jedipi/Quick-Stocktaker" />
                                </Span.GestureRecognizers>
                            </Span>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <StackLayout Orientation="Vertical" VerticalOptions="Center" IsVisible="Collapse">

                    <!--<StackLayout Orientation="Horizontal" VerticalOptions="Center" Margin="0,10,0,10" >
                        <StackLayout.GestureRecognizers>
                            <TapGestureRecognizer x:DataType="{x:Null}" Command="{Binding CommentCommand}"></TapGestureRecognizer>
                        </StackLayout.GestureRecognizers>
                        <Label Text="{x:Static fa:FontAwesomeFreeReg.Comment}" FontFamily="FA" 
                                           FontSize="Large" Margin="0,0,30,0" 
                                           VerticalTextAlignment="Center" />
                        <Label Text="Send feedback" FontSize="Medium" VerticalTextAlignment="Center" />
                    </StackLayout>-->
                    <Border  Stroke="{StaticResource Primary}" StrokeThickness="1" StrokeShape="Line 0 0 2000 0"/>

                    <StackLayout Orientation="Horizontal" Margin="0,10,0,10">
                        <StackLayout.GestureRecognizers>
                            <TapGestureRecognizer x:DataType="viewModels:AboutViewModel" Command="{Binding DonationCommand}"></TapGestureRecognizer>
                        </StackLayout.GestureRecognizers>
                        <Label Text="{x:Static fa:FontAwesomeFreeReg.DollarSign}" FontFamily="FA" 
                                           FontSize="Large" Margin="5,0,30,0" 
                                           VerticalTextAlignment="Center" />
                        <Label Text="Buy me cup of coffee" FontSize="Medium" VerticalTextAlignment="Center"/>
                    </StackLayout>
                    <!--<Border  Stroke="{StaticResource Primary}" StrokeThickness="1" StrokeShape="Line 0 0 2000 0"/>-->

                </StackLayout>
            </StackLayout>

        </ScrollView>

    </ContentPage.Content>
</ContentPage>
